# Build stage
FROM golang:1.26-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/queue cmd/queue/main.go

# Runtime stage
FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /bin/queue /queue
USER 65532:65532
ENTRYPOINT ["/queue"]
